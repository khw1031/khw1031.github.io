---
import PostList from '../components/PostList.astro';
import { Content as HomeIntro } from '../copy/home.md';
import Base from '../layouts/Base.astro';
import { getRecentAcrossCollections } from '../lib/collections';
import { personJsonLd, websiteJsonLd } from '../lib/jsonld';

const recent = await getRecentAcrossCollections(10);
const siteUrl = Astro.site?.toString() ?? 'https://khw1031.github.io/';
const jsonLd = [websiteJsonLd({ siteUrl }), personJsonLd({ siteUrl })];
---

<Base title="thnkr" description="개발 노트와 이력을 정리하는 공간." jsonLd={jsonLd}>
  <section class="prose max-w-none">
    <HomeIntro />
  </section>
  <section class="mt-6">
    <h2 class="font-medium mb-3">Recent</h2>
    <PostList items={recent} />
  </section>
</Base>
