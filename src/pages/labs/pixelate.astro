  .file-control span,
  .pixelate-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0 0.65rem;
  }

  .palette-options,
  .dither-options {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .palette-options label,
  .dither-options label {
    position: relative;
    display: inline-flex;
