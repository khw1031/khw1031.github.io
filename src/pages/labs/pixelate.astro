    min-height: 1.9rem;
    word-break: normal;
    overflow-wrap: normal;
    white-space: nowrap;
  }

  .range-control input {
    width: 100%;
    accent-color: var(--color-foreground);
  }

  .range-control output {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .color-control {
