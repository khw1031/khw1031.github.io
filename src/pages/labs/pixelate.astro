    justify-content: center;
    min-height: 2rem;
    min-width: 4.8rem;
    padding: 0 0.6rem;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    cursor: pointer;
  }

  .palette-options label:has(input:checked),
  .dither-options label:has(input:checked) {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .palette-options input,
  .dither-options input {
    position: absolute;
    inset: 0;
