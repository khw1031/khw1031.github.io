    gap: 0.45rem;
  }

  .upload-control,
  .palette-control,
  .dither-control {
    display: grid;
    grid-template-columns: 5.8rem minmax(0, 1fr);
    align-items: center;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .control-label,
  .palette-control legend,
  .dither-control legend {
    padding: 0;
    color: var(--color-muted);
  }

  .file-control {
    position: relative;
    display: inline-grid;
    justify-self: start;
    min-height: 2rem;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    cursor: pointer;
  }

  .file-control input {
