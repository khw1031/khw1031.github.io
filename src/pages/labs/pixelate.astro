  }

  .color-control input {
    width: 3rem;
    height: 1.7rem;
    padding: 0;
    border: 1px solid var(--color-border);
    background: transparent;
  }

  .pixelate-actions button {
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    font: inherit;
    cursor: pointer;
  }

  .pixelate-actions button[aria-label] {
    width: 2rem;
    padding: 0;
  }

  .file-control:hover,
  .palette-options label:hover,
  .dither-options label:hover,
  .pixelate-actions button:hover:not(:disabled) {
