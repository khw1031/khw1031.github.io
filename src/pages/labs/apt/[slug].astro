---
import Base from '../../../layouts/Base.astro';
import { aptRegistry, type AptEntry } from '../../../lib/apt/registry';

export function getStaticPaths() {
  return Object.entries(aptRegistry).map(([slug, entry]) => ({
    params: { slug },
    props: { entry },
  }));
}

interface Props {
  entry: AptEntry;
}

const { entry } = Astro.props;
const sourceUrl = `${import.meta.env.BASE_URL}labs/apt/source.jpg`;

const isVariation = entry.scene === 'corner-variation';
const pipeline = isVariation
  ? 'synthetic-2point-perspective-corner'
  : 'photo-structure-to-hopper-masses';
const variantJson = isVariation ? JSON.stringify(entry.variant) : undefined;
---

<Base title={`${entry.title} | Apt | Labs | thnkr`} description={entry.description}>
  <article class="space-y-4">
    <header class="space-y-1">
      <p class="text-sm text-muted"><a href="/labs/apt/">edward hopper apt</a></p>
      <h1 class="font-medium">{entry.title}</h1>
    </header>

    <section
      class="apt-workbench"
      aria-label="edward hopper apt scene"
      data-source={entry.sourcePhrase}
      data-abstraction={entry.abstraction}
      data-style-reference={entry.styleReference.title}
      data-scene={entry.scene}
      data-pipeline={pipeline}
      data-variant={variantJson}
      data-source-image={sourceUrl}
    >
      <div class="apt-stage">
        <canvas
          id="apt-canvas"
          class="apt-canvas"
          width="900"
          height="1350"
          aria-label={entry.description}
        >
        </canvas>
      </div>
    </section>

    <section class="apt-method space-y-2">
      <p class="text-sm text-muted">
        Claude Opus 4.8 (<code>claude-opus-4-8</code>). 기준 컨셉: {entry.styleReference.artist},
        <em>{entry.styleReference.title}</em> ({entry.styleReference.year}). {entry.credit}
      </p>
      {
        entry.reproUrl && (
          <p class="text-sm text-muted">
            <a href={entry.reproUrl} target="_blank" rel="noopener noreferrer">
              gist
            </a>
          </p>
        )
      }
    </section>
  </article>
</Base>

<script>
  const workbench = document.querySelector<HTMLElement>('.apt-workbench');
  const canvas = document.querySelector<HTMLCanvasElement>('#apt-canvas');

  if (!canvas || !workbench) {
    throw new Error('Missing apt canvas.');
  }

  const context = canvas.getContext('2d', { willReadFrequently: true });

  if (!context) {
    throw new Error('Missing apt canvas context.');
  }

  const W = canvas.width;
  const H = canvas.height;
  const sourceUrl = workbench.dataset.sourceImage ?? '';
  const scene = workbench.dataset.scene ?? 'corner-mass';

  // The photo supplies only STRUCTURE — the corner silhouette and roofline. Everything
  // painted here is invented in the manner of Hopper's Rooms by the Sea: one raking
  // light (a warm sunlit face meeting a cool shadow face at a hard corner), sparse
  // windows in large blank wall — a few lit warm at dusk — under a wide empty sky, all
  // laid in with visible matte brushwork.
  const C = {
    skyTop: '#3c7191',
    skyLow: '#82a4b6',
    litBase: '#e2d6b4', // ivory (sunlit face)
    litTop: '#f2ecd6', // bright ivory highlight
    litBrushLight: '#fbf6e6',
    litBrushDark: '#cdbb8f',
    shadowBase: '#ab9c7f', // ivory drawn into shadow (warm greige)
    shadowDeep: '#6f6349',
    shadowBrushLight: '#c3b596',
    shadowBrushDark: '#574d3b',
    eave: '#5a5038',
  };

  const seeded = (s: number) => {
    let c = s >>> 0;
    return () => {
      c += 0x6d2b79f5;
      let t = c;
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  };

  const hexRgb = (hex: string): [number, number, number] => {
    const n = Number.parseInt(hex.slice(1), 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  };

  const traceFace = (roof: Float64Array, x0: number, x1: number) => {
    context.beginPath();
    context.moveTo(x0, H);
    context.lineTo(x0, roof[x0] ?? H);
    for (let x = x0; x <= x1; x += 1) context.lineTo(x, roof[x] ?? H);
    context.lineTo(x1, H);
    context.closePath();
  };

  const gradFill = (top: string, bottom: string) => {
    const g = context.createLinearGradient(0, 0, 0, H);
    g.addColorStop(0, top);
    g.addColorStop(1, bottom);
    context.fillStyle = g;
    context.fillRect(0, 0, W, H);
  };

  // Broad directionless blooms — matte tonal variation without any grain direction.
  const mottle = (
    clip: () => void,
    seed: number,
    light: string,
    dark: string,
    count: number,
    radiusFraction: number,
    maxAlpha: number,
  ) => {
    const random = seeded(seed);
    context.save();
    clip();
    context.clip();
    for (let i = 0; i < count; i += 1) {
      const cx = random() * W;
      const cy = H * 0.3 + random() * H * 0.7;
      const radius = W * radiusFraction * (0.5 + random() * 0.7);
      const [r, g, b] = hexRgb(random() > 0.5 ? light : dark);
      const a = maxAlpha * (0.4 + random() * 0.6);
      const grad = context.createRadialGradient(cx, cy, 0, cx, cy, radius);
      grad.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${a})`);
      grad.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
      context.fillStyle = grad;
      context.beginPath();
      context.arc(cx, cy, radius, 0, Math.PI * 2);
      context.fill();
    }
    context.restore();
  };

  // Value noise (hash grid + smoothstep bilerp, a few octaves) → an organic, direction-
  // less field used to vary the paint's value like hand-mixed pigment, never as strokes.
  const hashNoise = (x: number, y: number) => {
    let h = Math.imul(x | 0, 374761393) ^ Math.imul(y | 0, 668265263);
    h = Math.imul(h ^ (h >>> 13), 1274126177);
    return ((h ^ (h >>> 16)) >>> 0) / 4294967295;
  };
  const smoothNoise = (x: number, y: number) => {
    const xi = Math.floor(x);
    const yi = Math.floor(y);
    const xf = x - xi;
    const yf = y - yi;
    const u = xf * xf * (3 - 2 * xf);
    const v = yf * yf * (3 - 2 * yf);
    const a = hashNoise(xi, yi);
    const b = hashNoise(xi + 1, yi);
    const c = hashNoise(xi, yi + 1);
    const d = hashNoise(xi + 1, yi + 1);
    return a * (1 - u) * (1 - v) + b * u * (1 - v) + c * (1 - u) * v + d * u * v;
  };
  const fbm = (x: number, y: number) => {
    let sum = 0;
    let amp = 0.5;
    let freq = 1;
    for (let o = 0; o < 3; o += 1) {
      sum += amp * smoothNoise(x * freq, y * freq);
      freq *= 2.1;
      amp *= 0.5;
    }
    return sum;
  };

  // Modulate the painting's value by (A) a faint regular canvas weave and (B) soft
  // organic noise. A coarse low-frequency field varies the texture DENSITY across the
  // surface, so it pools and thins irregularly like hand-applied paint rather than
  // sitting at a uniform strength — and no visible strokes or grid.
  const applyPaintTexture = () => {
    const img = context.getImageData(0, 0, W, H);
    const d = img.data;
    for (let y = 0; y < H; y += 1) {
      for (let x = 0; x < W; x += 1) {
        const o = (y * W + x) * 4;
        const density = 0.3 + 1.4 * fbm(x / 150 + 200, y / 150 + 200); // random-ish density
        const weave = (Math.sin(x * 1.15) + Math.sin(y * 1.15)) * 0.5; // A: canvas weave
        const n = fbm(x / 46, y / 46) - 0.5; // B: soft cloud
        const n2 = fbm(x / 12 + 50, y / 12 + 50) - 0.5; // B: finer tooth
        const delta = 0.016 * weave + 0.036 * n + 0.018 * n2;
        const f = 1 + delta * density;
        d[o] = Math.min(255, (d[o] ?? 0) * f);
        d[o + 1] = Math.min(255, (d[o + 1] ?? 0) * f);
        d[o + 2] = Math.min(255, (d[o + 2] ?? 0) * f);
      }
    }
    context.putImageData(img, 0, 0);
  };

  const grain = () => {
    const random = seeded(90210);
    context.save();
    for (let i = 0; i < 3000; i += 1) {
      const light = random() > 0.7;
      context.globalAlpha = light ? 0.025 : 0.04;
      context.fillStyle = light ? '#f3e7c8' : '#20190f';
      context.fillRect(Math.floor(random() * W), Math.floor(random() * H), 1, 1);
    }
    context.restore();
  };

  const paintScene = (roof: Float64Array, apex: number) => {
    const leftClip = () => traceFace(roof, 0, apex);
    const rightClip = () => traceFace(roof, apex, W - 1);
    gradFill(C.skyTop, C.skyLow);

    // Left face takes the light; right face falls into shadow. The corner between them
    // is a hard value jump, not a drawn line. Soft mottle gives matte tonal variation.
    context.save();
    leftClip();
    context.clip();
    gradFill(C.litTop, C.litBase);
    context.restore();
    mottle(leftClip, 3391, C.litBrushLight, C.litBrushDark, 12, 0.22, 0.09);

    context.save();
    rightClip();
    context.clip();
    gradFill(C.shadowBase, C.shadowDeep);
    context.restore();
    mottle(rightClip, 8123, C.shadowBrushLight, C.shadowBrushDark, 10, 0.18, 0.12);

    // A thin eave shadow riding just under the sunlit roofline.
    context.save();
    leftClip();
    context.clip();
    context.globalAlpha = 0.24;
    context.fillStyle = C.eave;
    context.beginPath();
    context.moveTo(0, roof[0] ?? H);
    for (let x = 0; x <= apex; x += 1) context.lineTo(x, roof[x] ?? H);
    for (let x = apex; x >= 0; x -= 1) context.lineTo(x, (roof[x] ?? H) + 20);
    context.closePath();
    context.fill();
    context.restore();

    applyPaintTexture();
    grain();
  };

  // A cluster of apartment blocks in apt.1's grammar — sunlit face meeting shadow face at
  // a hard corner, matte brushwork, wide empty sky, NO ground shown (each block runs to
  // the bottom edge). The whole cluster shares ONE horizon and TWO vanishing points, so
  // every block is built in the same TRUE 2-point perspective and reads as one coherent
  // block of buildings. Each apartment takes a different color; the light is consistent
  // (left faces lit). Everything is synthetic; no photo is used.
  interface FacePalette {
    litTop: string;
    litBase: string;
    litBrushLight: string;
    litBrushDark: string;
    shadowBase: string;
    shadowDeep: string;
    shadowBrushLight: string;
    shadowBrushDark: string;
    eave: string;
  }
  interface ExplicitBlock {
    cx: number; // near corner x (fraction of W)
    yT: number; // roof height (fraction of H)
    lx: number; // left (lit) face far edge (fraction of W)
    rx: number; // right (shadow) face far edge (fraction of W)
    palette: number; // index into APARTMENT_PALETTES
  }
  interface Variant {
    seed: number; // deterministic layout seed
    count: number; // number of apartment blocks
    horizonY: number; // eye level / vanishing-point height (fraction of H)
    vpLeftX: number; // left vanishing point x (fraction of W, off-canvas)
    vpRightX: number; // right vanishing point x (fraction of W, off-canvas)
    skyTop: string;
    skyLow: string;
    blocks?: ExplicitBlock[]; // art-directed layout; overrides procedural generation
  }

  const APARTMENT_PALETTES: FacePalette[] = [
    {
      litTop: '#f2ecd6', // ivory
      litBase: '#e2d6b4',
      litBrushLight: '#fbf6e6',
      litBrushDark: '#cdbb8f',
      shadowBase: '#ab9c7f',
      shadowDeep: '#6f6349',
      shadowBrushLight: '#c3b596',
      shadowBrushDark: '#574d3b',
      eave: '#5a5038',
    },
    {
      litTop: '#f2cd9c', // amber
      litBase: '#d79b5f',
      litBrushLight: '#f9dcb4',
      litBrushDark: '#b57f3e',
      shadowBase: '#875f3b',
      shadowDeep: '#48321f',
      shadowBrushLight: '#a07a4e',
      shadowBrushDark: '#3a2817',
      eave: '#3f2c1a',
    },
    {
      litTop: '#e8b9a3', // terracotta
      litBase: '#cf9179',
      litBrushLight: '#f2cdba',
      litBrushDark: '#b0725c',
      shadowBase: '#8a5a49',
      shadowDeep: '#4c2f26',
      shadowBrushLight: '#a2705d',
      shadowBrushDark: '#3a231c',
      eave: '#3c241d',
    },
    {
      litTop: '#e6ebe4', // sage grey-green
      litBase: '#c8d0c6',
      litBrushLight: '#f1f4ee',
      litBrushDark: '#aab3a6',
      shadowBase: '#8b948c',
      shadowDeep: '#4f564f',
      shadowBrushLight: '#a7afa6',
      shadowBrushDark: '#3c423c',
      eave: '#454b45',
    },
    {
      litTop: '#dce0ea', // slate blue
      litBase: '#bcc2d4',
      litBrushLight: '#ebedf4',
      litBrushDark: '#a0a6bc',
      shadowBase: '#727a94',
      shadowDeep: '#3e4459',
      shadowBrushLight: '#8a90a8',
      shadowBrushDark: '#2f3444',
      eave: '#363b4a',
    },
    {
      litTop: '#ece5da', // warm taupe
      litBase: '#d3c9ba',
      litBrushLight: '#f4efe6',
      litBrushDark: '#b3a793',
      shadowBase: '#8f8272',
      shadowDeep: '#524a3d',
      shadowBrushLight: '#a89a86',
      shadowBrushDark: '#3c352b',
      eave: '#443c30',
    },
    // --- sage family (indices 6-9): subtle shifts of the base sage for a single-tone look
    {
      litTop: '#eaeade', // 6 sage — warm (toward olive)
      litBase: '#cdd0bd',
      litBrushLight: '#f3f3e7',
      litBrushDark: '#b0b39c',
      shadowBase: '#8f9080',
      shadowDeep: '#524f42',
      shadowBrushLight: '#abac97',
      shadowBrushDark: '#3f3e30',
      eave: '#48473a',
    },
    {
      litTop: '#e2ebec', // 7 sage — cool (toward blue)
      litBase: '#c2ced2',
      litBrushLight: '#eef3f4',
      litBrushDark: '#a4b1b4',
      shadowBase: '#85929a',
      shadowDeep: '#4a555c',
      shadowBrushLight: '#a1aeb3',
      shadowBrushDark: '#38424a',
      eave: '#414b52',
    },
    {
      litTop: '#eef2ec', // 8 sage — light
      litBase: '#d6ddd4',
      litBrushLight: '#f7f9f4',
      litBrushDark: '#bcc4b8',
      shadowBase: '#9aa39b',
      shadowDeep: '#5c635a',
      shadowBrushLight: '#b4bbb2',
      shadowBrushDark: '#474e46',
      eave: '#515850',
    },
    {
      litTop: '#dde3da', // 9 sage — deep
      litBase: '#bcc5b8',
      litBrushLight: '#e9eee5',
      litBrushDark: '#9ea798',
      shadowBase: '#7e887d',
      shadowDeep: '#434a41',
      shadowBrushLight: '#99a294',
      shadowBrushDark: '#333930',
      eave: '#3c423a',
    },
    // --- ivory family (indices 10-13): subtle shifts of the base ivory (index 0)
    {
      litTop: '#f4ebcf', // 10 ivory — warm
      litBase: '#e6d3ab',
      litBrushLight: '#fcf4e0',
      litBrushDark: '#d1bb87',
      shadowBase: '#b09a79',
      shadowDeep: '#726343',
      shadowBrushLight: '#c7b48f',
      shadowBrushDark: '#5a4c36',
      eave: '#5d5033',
    },
    {
      litTop: '#efecdc', // 11 ivory — cool
      litBase: '#ddd6bb',
      litBrushLight: '#f8f5e8',
      litBrushDark: '#c6bd97',
      shadowBase: '#a49b86',
      shadowDeep: '#696351',
      shadowBrushLight: '#bdb59e',
      shadowBrushDark: '#524d40',
      eave: '#565042',
    },
    {
      litTop: '#f6f0de', // 12 ivory — light
      litBase: '#e9dec0',
      litBrushLight: '#fdf9ec',
      litBrushDark: '#d5c69b',
      shadowBase: '#b6a98d',
      shadowDeep: '#7a6f59',
      shadowBrushLight: '#ccc0a2',
      shadowBrushDark: '#625848',
      eave: '#665c48',
    },
    {
      litTop: '#ece4c9', // 13 ivory — deep
      litBase: '#d8caa4',
      litBrushLight: '#f5eed9',
      litBrushDark: '#c1ad80',
      shadowBase: '#9d8e70',
      shadowDeep: '#64583f',
      shadowBrushLight: '#b6a781',
      shadowBrushDark: '#4e4432',
      eave: '#524731',
    },
  ];
  // Procedural clusters (apt.3-5) use only the first six base colors; the sage-family
  // extras above are for the art-directed single-tone preview.
  const BASE_PALETTE_COUNT = 6;

  interface Block {
    cx: number;
    yT: number;
    lx: number;
    rx: number;
    palette: FacePalette;
  }

  const paintCornerCluster = (v: Variant) => {
    const hY = H * v.horizonY;
    const vlx = W * v.vpLeftX;
    const vrx = W * v.vpRightX;

    // Roof/base edge leaving a block's near corner (cx, yEdge) recedes toward the
    // vanishing point (vpx, hY); at column x it sits at this y. Base is pinned to the
    // frame bottom so no ground is ever shown.
    const edgeY = (cx: number, x: number, yEdge: number, vpx: number) =>
      yEdge + (hY - yEdge) * ((x - cx) / (vpx - cx));

    // Deterministic layout: spread near-corners across the frame with jitter, vary
    // heights and face widths, cycle palettes. Sort back-to-front by height (shorter
    // blocks sit behind taller ones) so nearer blocks overlap farther ones.
    const blocks: Block[] = [];
    if (v.blocks && v.blocks.length > 0) {
      // Art-directed layout: explicit blocks in fractional coordinates.
      for (const b of v.blocks) {
        blocks.push({
          cx: W * b.cx,
          yT: H * b.yT,
          lx: W * b.lx,
          rx: W * b.rx,
          palette: APARTMENT_PALETTES[b.palette % APARTMENT_PALETTES.length] as FacePalette,
        });
      }
    } else {
      // Deterministic procedural layout.
      const random = seeded(v.seed);
      for (let i = 0; i < v.count; i += 1) {
        // Position: spread near-corners across the frame with jitter.
        const slot = (i + 0.5) / v.count;
        const cxFrac = slot + (random() - 0.5) * (0.85 / v.count);
        const cx = W * cxFrac;
        // Height: a wide spread from short blocks to tall towers.
        const yT = H * (0.28 + random() * 0.44);
        // Size + face lengths: an overall footprint width, split by a corner ratio, so the
        // two visible faces differ (a broad face and a narrow one, as if seen at an angle).
        const totalW = W * (0.14 + random() * 0.32);
        const ratio = 0.28 + random() * 0.44;
        const lx = cx - totalW * ratio;
        const rx = cx + totalW * (1 - ratio);
        const palette = APARTMENT_PALETTES[i % BASE_PALETTE_COUNT] as FacePalette;
        blocks.push({ cx, yT, lx, rx, palette });
      }
      // Procedural depth: shorter blocks sit behind taller ones.
      blocks.sort((a, b) => b.yT - a.yT);
    }
    // Explicit blocks keep their given order (drawn back-to-front), so a block's height
    // never changes what it overlaps — only the array order does.

    gradFill(v.skyTop, v.skyLow);

    for (const b of blocks) {
      const { cx, yT, lx, rx, palette: p } = b;
      // Left face is lit, right face falls into shadow (consistent light direction).
      const litFace = () => {
        context.beginPath();
        context.moveTo(cx, yT);
        context.lineTo(lx, edgeY(cx, lx, yT, vlx));
        context.lineTo(lx, H);
        context.lineTo(cx, H);
        context.closePath();
      };
      const shadowFace = () => {
        context.beginPath();
        context.moveTo(cx, yT);
        context.lineTo(rx, edgeY(cx, rx, yT, vrx));
        context.lineTo(rx, H);
        context.lineTo(cx, H);
        context.closePath();
      };

      context.save();
      litFace();
      context.clip();
      gradFill(p.litTop, p.litBase);
      context.restore();
      mottle(litFace, v.seed + Math.round(cx), p.litBrushLight, p.litBrushDark, 8, 0.14, 0.08);

      context.save();
      shadowFace();
      context.clip();
      gradFill(p.shadowBase, p.shadowDeep);
      context.restore();
      mottle(shadowFace, v.seed + Math.round(cx) + 97, p.shadowBrushLight, p.shadowBrushDark, 6, 0.12, 0.1);

      // Thin eave shadow following the lit roof edge's slope.
      const farY = edgeY(cx, lx, yT, vlx);
      context.save();
      litFace();
      context.clip();
      context.globalAlpha = 0.24;
      context.fillStyle = p.eave;
      context.beginPath();
      context.moveTo(cx, yT);
      context.lineTo(lx, farY);
      context.lineTo(lx, farY + 16);
      context.lineTo(cx, yT + 16);
      context.closePath();
      context.fill();
      context.restore();
    }

    applyPaintTexture();
    grain();
  };

  const rooflineFromPhoto = (image: HTMLImageElement) => {
    const targetRatio = W / H;
    let sw = image.naturalWidth;
    let sh = image.naturalHeight;
    let sx = 0;
    let sy = 0;
    if (image.naturalWidth / image.naturalHeight > targetRatio) {
      sw = image.naturalHeight * targetRatio;
      sx = (image.naturalWidth - sw) / 2;
    } else {
      sh = image.naturalWidth / targetRatio;
      sy = (image.naturalHeight - sh) / 2;
    }
    context.drawImage(image, sx, sy, sw, sh, 0, 0, W, H);
    const data = context.getImageData(0, 0, W, H).data;

    // Roofline = first non-sky pixel per column (sky ≈ bright and blue-dominant).
    const raw = new Float64Array(W);
    for (let x = 0; x < W; x += 1) {
      let y = 0;
      for (; y < H; y += 1) {
        const o = (y * W + x) * 4;
        const r = data[o] ?? 0;
        const g = data[o + 1] ?? 0;
        const b = data[o + 2] ?? 0;
        if (!(b > 110 && b >= g - 6 && b > r + 8)) break;
      }
      raw[x] = y;
    }
    const roof = new Float64Array(W);
    const win = 9;
    for (let x = 0; x < W; x += 1) {
      let sum = 0;
      let count = 0;
      for (let k = -win; k <= win; k += 1) {
        const xx = x + k;
        if (xx >= 0 && xx < W) {
          sum += raw[xx] ?? 0;
          count += 1;
        }
      }
      roof[x] = Math.min(H, sum / count);
    }

    let apex = Math.floor(W / 2);
    let apexY = H;
    for (let x = 0; x < W; x += 1) {
      const value = roof[x] ?? H;
      if (value < apexY && value < H - 2) {
        apexY = value;
        apex = x;
      }
    }
    return { roof, apex };
  };

  const syntheticRoofline = () => {
    const apex = Math.round(W * 0.42);
    const apexY = H * 0.34;
    const roof = new Float64Array(W);
    for (let x = 0; x < W; x += 1) {
      roof[x] =
        x <= apex
          ? H * 0.47 + (apexY - H * 0.47) * (x / apex)
          : apexY + (H * 0.5 - apexY) * ((x - apex) / (W - 1 - apex));
    }
    return { roof, apex };
  };

  if (scene === 'corner-variation') {
    const variant = JSON.parse(workbench.dataset.variant ?? '{}') as Variant;
    paintCornerCluster(variant);
    canvas.dataset.rendered = 'true';
  } else {
    const image = new Image();
    image.onload = () => {
      const { roof, apex } = rooflineFromPhoto(image);
      paintScene(roof, apex);
      canvas.dataset.rendered = 'true';
    };
    image.onerror = () => {
      const { roof, apex } = syntheticRoofline();
      paintScene(roof, apex);
      canvas.dataset.rendered = 'fallback';
    };
    image.src = sourceUrl;
  }
</script>

