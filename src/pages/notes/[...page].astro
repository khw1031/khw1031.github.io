---
import type { GetStaticPaths, Page } from 'astro';
import Pagination from '../../components/Pagination.astro';
import PostList from '../../components/PostList.astro';
import { Content as Intro } from '../../copy/notes.md';
import Base from '../../layouts/Base.astro';
import { COLLECTION_LABELS, type PostListItem, getListItems } from '../../lib/collections';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const all = await getListItems('notes');
  // Child notes (e.g. /notes/foo/bar/ under the hub /notes/foo/) are reachable
  // from their hub's TOC; only hubs and standalone notes appear in the list.
  const items = all.filter(
    (item) => !all.some((other) => other !== item && item.href.startsWith(other.href)),
  );
  return paginate(items, { pageSize: 10 });
};

const { page } = Astro.props as { page: Page<PostListItem> };
const title = COLLECTION_LABELS.notes;
---

<Base title={`${title} — thnkr`} description={`${title} — 개인 노트`}>
  <section class="prose max-w-none">
    <Intro />
  </section>
  <section class="mt-6">
    <h2 class="font-medium mb-3">{title}</h2>
    <PostList items={page.data} />
    <Pagination page={page} />
  </section>
</Base>
