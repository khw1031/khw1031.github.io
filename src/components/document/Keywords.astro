---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="mt-8">
      <h2 class="text-base font-semibold border-b border-border pb-1">기술 스택</h2>
      <p class="mt-2 text-sm text-muted">{items.join(' · ')}</p>
    </section>
  )
}
