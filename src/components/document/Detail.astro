---
import type { Detail } from '../../data/types';

interface Props {
  detail: Detail;
}

const { detail } = Astro.props;
const isExternal = (href?: string) => Boolean(href && /^https?:\/\//.test(href));

const metaParts: string[] = [];
if (detail.role) metaParts.push(detail.role);
if (detail.period) metaParts.push(detail.period);

const singleContent = detail.content.length === 1 ? detail.content[0] : undefined;
const inlineContentTitle =
  singleContent?.title && singleContent.description.length === 0 ? singleContent.title : undefined;
if (inlineContentTitle) metaParts.push(inlineContentTitle);

const blockContent = inlineContentTitle ? [] : detail.content;
---

<article class="mt-3 bg-foreground/[0.025] px-4 py-3">
  <header class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
    {detail.title && (
      <h3 class="text-base font-semibold">
        {
          detail.url ? (
            <a
              href={detail.url}
              {...(isExternal(detail.url)
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              {detail.title}
            </a>
          ) : (
            detail.title
          )
        }
      </h3>
    )}
    {
      (metaParts.length > 0 || detail.ect) && (
        <p class="text-xs text-muted">
          {metaParts.map((part, idx) => (
            <>
              {idx > 0 && <span aria-hidden="true"> · </span>}
              {part}
            </>
          ))}
          {detail.ect && (
            <>
              <span aria-hidden="true"> · </span>
              <span>※ {detail.ect}</span>
            </>
          )}
        </p>
      )
    }
  </header>
  {detail.subtitle && <p class="text-sm text-muted">{detail.subtitle}</p>}
  {
    blockContent.length > 0 && (
      <div class="mt-3 flex flex-col gap-4">
        {blockContent.map((item) => (
          <div>
            {item.title && <h4 class="text-sm font-semibold">{item.title}</h4>}
            {item.description.length > 0 &&
              (item.kind === 'prose' ? (
                <div class="mt-1.5 text-sm text-muted space-y-1.5">
                  {item.description.map((line) => (
                    <p>{line}</p>
                  ))}
                </div>
              ) : (
                <ul class="mt-1.5 ml-4 list-disc text-sm text-muted space-y-1.5">
                  {item.description.map((line) => (
                    <li>{line}</li>
                  ))}
                </ul>
              ))}
          </div>
        ))}
      </div>
    )
  }
</article>
