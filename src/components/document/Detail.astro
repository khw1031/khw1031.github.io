---
import type { Detail } from '../../data/types';

interface Props {
  detail: Detail;
}

const { detail } = Astro.props;
const isExternal = (href?: string) => Boolean(href && /^https?:\/\//.test(href));

// A single title-only content block (e.g. education) collapses into the meta
// line rather than rendering as a body block.
const singleContent = detail.content.length === 1 ? detail.content[0] : undefined;
const inlineContentTitle =
  singleContent?.title && singleContent.description.length === 0 ? singleContent.title : undefined;

// Period is pulled out into its own right-aligned column (typed-document
// alignment); the remaining facts form a muted sub-line under the title.
const metaParts: string[] = [];
if (detail.role) metaParts.push(detail.role);
if (inlineContentTitle) metaParts.push(inlineContentTitle);
if (detail.ect) metaParts.push(`※ ${detail.ect}`);

const blockContent = inlineContentTitle ? [] : detail.content;
const hasContent = blockContent.length > 0;

// A trailing parenthetical in a dense-entry title (e.g. "현대엘엔씨(구 한화L&C)")
// is a former-name annotation: split it off so it can render smaller and muted.
// A leading parenthetical like "(주)한샘" is part of the name and never matches.
const formerNameMatch = detail.title?.match(/^(.*\S)\s*(\([^)]*\))$/);
const mainTitle = formerNameMatch ? formerNameMatch[1] : detail.title;
const titleAnnotation = formerNameMatch ? formerNameMatch[2] : undefined;

// A period range ("start — end") is split so mobile can break after the
// separator into two lines deterministically, independent of viewport width;
// on sm+ the <br> is hidden and it renders on a single line. Single dates
// (no separator) render as-is.
const periodRange = detail.period?.match(/^(.*\S)\s*([—–-])\s*(\S.*)$/);
---

<article
  class:list={[
    hasContent ? 'mt-16' : 'mt-2',
    'first:mt-0',
    'grid grid-cols-[11ch_1fr] items-baseline gap-x-4 sm:grid-cols-[23ch_1fr]',
  ]}
>
  <div class="text-xs text-muted tabular-nums">
    {
      periodRange ? (
        <>
          <span class="whitespace-nowrap">
            {periodRange[1]} {periodRange[2]}
          </span>{' '}
          <br class="sm:hidden" />
          {periodRange[3]}
        </>
      ) : (
        detail.period
      )
    }
  </div>
  <div class="min-w-0">
    {
      hasContent ? (
        // On mobile the role/meta stacks below the title (no leading dot); on
        // sm+ it stays inline after the title joined by a single dot.
        <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-baseline sm:gap-x-1.5">
          {detail.title && (
            <h3 class="text-base font-semibold">
              {detail.url ? (
                <a
                  href={detail.url}
                  {...(isExternal(detail.url)
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {detail.title}
                </a>
              ) : (
                detail.title
              )}
            </h3>
          )}
          {metaParts.length > 0 && (
            <span class="mt-0.5 text-xs text-muted sm:mt-0">
              <span aria-hidden="true" class="hidden sm:inline">
                ·{' '}
              </span>
              {metaParts.join(' · ')}
            </span>
          )}
        </div>
      ) : (
        // Dense entries (career, education): a lighter, smaller title. On mobile
        // the role/meta stacks below the title (no leading dot); on sm+ it stays
        // inline after the title joined by a single dot.
        <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-baseline sm:gap-x-1.5">
          {detail.title && (
            <h3 class="text-[12px] font-normal">
              {detail.url ? (
                <a
                  href={detail.url}
                  {...(isExternal(detail.url)
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {mainTitle}
                </a>
              ) : (
                mainTitle
              )}
              {titleAnnotation && (
                <span class="ml-0.5 text-[11px] font-normal text-muted">{titleAnnotation}</span>
              )}
            </h3>
          )}
          {metaParts.length > 0 && (
            <span class="mt-0.5 text-xs text-muted sm:mt-0">
              <span aria-hidden="true" class="hidden sm:inline">
                ·{' '}
              </span>
              {metaParts.join(' · ')}
            </span>
          )}
        </div>
      )
    }
    {detail.subtitle && <p class="mt-0.5 text-sm text-muted">{detail.subtitle}</p>}
    {
      hasContent && (
        <div class="mt-4 max-w-[64ch] text-[12px]/6 text-justify [text-justify:inter-character]">
          {blockContent.map((item) => (
            <div>
              {item.description.map((line) => (
                <p>{line}</p>
              ))}
            </div>
          ))}
        </div>
    )
  }
    {
      detail.impact.length > 0 && (
        <div class="mt-3 max-w-[64ch] text-[12px]/6">
          {detail.impact.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      )
    }
    {
      detail.references.length > 0 && (
        <div class="mt-3 text-[11px] text-right text-muted">
          <span aria-hidden="true">· </span>
          {detail.references.map((ref, idx) => (
            <>
              {idx > 0 && <span aria-hidden="true"> / </span>}
              <a
                href={ref.url}
                {...(isExternal(ref.url)
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {ref.label}
              </a>
            </>
          ))}
        </div>
      )
    }
  </div>
</article>
