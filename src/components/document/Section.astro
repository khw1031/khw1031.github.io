---
import type { Section } from '../../data/types';
import Detail from './Detail.astro';

interface Props {
  section: Section;
}

const { section } = Astro.props;
const showCareerDuration = section.title === '경력 사항';
---

<section class="mt-10">
  <h2 class="text-base font-semibold border-b border-border pb-2">
    {section.title}
  </h2>
  <div class="mt-3">
    {section.details.map((d) => <Detail detail={d} showDuration={showCareerDuration} />)}
  </div>
  {
    showCareerDuration && (
      <script>
        import { updateCareerDurationElements } from '../../lib/career-duration';

        updateCareerDurationElements();
      </script>
    )
  }
</section>
