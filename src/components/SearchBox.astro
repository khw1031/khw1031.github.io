---
import { Search } from '@lucide/astro';

// Text link ("Search" + trailing magnifier) shown next to the home hero. It is
// a plain link to the /search page (no input, no box), so tapping it never
// triggers mobile zoom. The /search page auto-focuses its Pagefind input.
---

<a
  href="/search/"
  role="button"
  aria-label="Search"
  class="not-prose inline-flex items-center gap-1.5 text-sm text-black hover:text-black/60 transition-colors"
>
  <span>Search</span>
  <Search size={13} aria-hidden="true" class="translate-y-0.5" />
</a>
