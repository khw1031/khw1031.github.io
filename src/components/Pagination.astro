---
import type { Page } from 'astro';

interface Props {
  page: Page<unknown>;
}

const { page } = Astro.props;
const hasMultiplePages = page.lastPage > 1;
---

{
  hasMultiplePages && (
    <nav
      class="mt-8 flex items-center justify-between border-t border-border pt-3 text-sm"
      aria-label="Pagination"
    >
      {page.url.prev ? (
        <a href={page.url.prev} rel="prev">
          ← prev
        </a>
      ) : (
        <span class="text-muted">← prev</span>
      )}
      <span class="text-muted">
        {page.currentPage} / {page.lastPage}
      </span>
      {page.url.next ? (
        <a href={page.url.next} rel="next">
          next →
        </a>
      ) : (
        <span class="text-muted">next →</span>
      )}
    </nav>
  )
}
