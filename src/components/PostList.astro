---
import { type PostListItem, formatDate } from '../lib/collections';

interface Props {
  items: PostListItem[];
}

const { items } = Astro.props;
---

<ul class="not-prose list-none p-0 m-0 space-y-3">
  {
    items.map((item) => (
      <li>
        <a href={item.href} class="text-foreground hover:underline underline-offset-2">
          {item.title}
        </a>
        <div class="text-sm text-muted">
          {item.label && (
            <>
              <span>{item.label}</span>
              <span> · </span>
            </>
          )}
          <time datetime={item.pubDate.toISOString()}>{formatDate(item.pubDate)}</time>
          {item.readingMinutes != null ? (
            <>
              <span> · </span>
              <span>{item.readingMinutes} min</span>
            </>
          ) : item.kind === 'lab' ? (
            <>
              <span> · </span>
              <span>lab</span>
            </>
          ) : null}
        </div>
      </li>
    ))
  }
</ul>
