---
import { type PostListItem, formatDate } from '../lib/collections';

interface Props {
  items: PostListItem[];
}

const { items } = Astro.props;

// List-display only: truncate long titles with an ellipsis.
// Full title stays intact in headings, SEO meta, and RSS.
const TITLE_MAX = 50;
const truncateTitle = (title: string) =>
  title.length > TITLE_MAX ? `${title.slice(0, TITLE_MAX).replace(/\s+$/, '')}…` : title;
---

<ul class="not-prose list-none p-0 m-0 space-y-5">
  {
    items.map((item) => (
      <li>
        <a
          href={item.href}
          title={item.title}
          class="text-foreground hover:underline underline-offset-2"
        >
          {truncateTitle(item.title)}
        </a>
        <div class="max-w-md">
          {item.description && (
            <p class="not-prose mt-0.5 mb-0 text-sm text-muted text-justify line-clamp-3">
              {item.description}
            </p>
          )}
          <div class="mt-1 text-sm text-muted">
          {item.label && (
            <>
              <span>{item.label}</span>
              <span> · </span>
            </>
          )}
          <time datetime={item.pubDate.toISOString()}>{formatDate(item.pubDate)}</time>
          {item.readingMinutes != null ? (
            <>
              <span> · </span>
              <span>{item.readingMinutes} min</span>
            </>
          ) : item.kind === 'lab' ? (
            <>
              <span> · </span>
              <span>labs</span>
            </>
          ) : null}
          </div>
        </div>
      </li>
    ))
  }
</ul>
