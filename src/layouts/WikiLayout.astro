---
import type { CollectionEntry } from 'astro:content';
import CopyMarkdown from '../components/CopyMarkdown.astro';
import CopyPath from '../components/CopyPath.astro';
import { formatDate } from '../lib/collections';
import { blogPostingJsonLd } from '../lib/jsonld';
import Base from './Base.astro';

interface Props {
  entry: CollectionEntry<'wiki'>;
  readingMinutes: number;
}

const { entry, readingMinutes } = Astro.props;
const { data } = entry;
const description = data.description ?? data.summary ?? '';
const siteUrl = Astro.site?.toString() ?? 'https://khw1031.github.io/';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const jsonLd = blogPostingJsonLd({
  title: data.title,
  description: description || undefined,
  pubDate: data.pubDate,
  updatedDate: data.updatedDate,
  url: pageUrl,
  siteUrl,
});
const mdHref = `${Astro.url.pathname.replace(/\/$/, '')}/raw.md`;
// entry.id folds `/index`, so prefer the loader-provided filePath for display.
const sourcePath = entry.filePath ?? `src/content/wiki/${entry.id}.md`;
// wiki is the public, searchable scope (unlike notes/inbox/specs): every non-draft
// doc goes into the pagefind index. Tag chips are intentionally omitted — the
// /tags pages cover only the timeline scope, so a wiki tag would 404.
const searchable = !data.draft;
---

<Base title={`${data.title} — thnkr`} description={description} jsonLd={jsonLd}>
  <div class="flex justify-end gap-4">
    <CopyMarkdown href={mdHref} />
    <CopyPath value={sourcePath} />
  </div>
  <article class="prose max-w-none mt-2" data-pagefind-body={searchable ? true : undefined}>
    <h1>{data.title}</h1>
    <div class="not-prose text-sm text-muted mb-6 flex flex-wrap items-center gap-x-2">
      <span
        class="border border-border px-1.5 py-0.5 text-[11px] uppercase tracking-wide"
        data-pagefind-filter="type"
      >
        {data.type}
      </span>
      <time datetime={data.pubDate.toISOString()} data-pagefind-meta="date">
        {formatDate(data.pubDate)}
      </time>
      <span>·</span>
      <span>{readingMinutes} min</span>
    </div>
    {
      data.summary && (
        <aside class="not-prose mb-14 text-[#4c82f0]">
          <div class="mb-1 flex items-center gap-1.5">
            <svg
              width="13.65"
              height="13.65"
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="tldr-mark shrink-0"
            >
              <path
                fill="currentColor"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linejoin="round"
                d="M12 2c0 5.523-4.477 10-10 10 5.523 0 10 4.477 10 10 0-5.523 4.477-10 10-10-5.523 0-10-4.477-10-10z"
              />
            </svg>
            <span class="text-[13px] font-semibold leading-none">핵심요약</span>
          </div>
          <p class="m-0 text-[13px] leading-relaxed">{data.summary}</p>
        </aside>
      )
    }
    <slot />
  </article>
</Base>

<style>
  /* Optical centering of the 핵심요약 glyph — mirrors PostLayout. */
  .tldr-mark {
    transform: translateY(0.5px);
  }

  @media (min-resolution: 2dppx) {
    .tldr-mark {
      transform: none;
    }
  }
</style>
