---
import type { CollectionEntry } from 'astro:content';
import CopyMarkdown from '../components/CopyMarkdown.astro';
import CopyPath from '../components/CopyPath.astro';
import { COLLECTION_ORDER, type ListableCollection, formatDate } from '../lib/collections';
import { blogPostingJsonLd } from '../lib/jsonld';
import Base from './Base.astro';

interface Props {
  entry: CollectionEntry<ListableCollection>;
  readingMinutes: number;
}

const { entry, readingMinutes } = Astro.props;
const { data } = entry;
const description = data.description ?? data.summary ?? '';
const siteUrl = Astro.site?.toString() ?? 'https://khw1031.github.io/';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const jsonLd = blogPostingJsonLd({
  title: data.title,
  description: description || undefined,
  pubDate: data.pubDate,
  updatedDate: data.updatedDate,
  url: pageUrl,
  siteUrl,
});
const mdHref = `${Astro.url.pathname.replace(/\/$/, '')}/raw.md`;
const showSourcePath = entry.collection === 'notes' || entry.collection === 'inbox';
const sourcePath = `src/content/${entry.collection}/${entry.id}.md`;
// Search principle: index only public, listed collections. Notes and inbox are
// unlisted (excluded from sitemap too) and must never enter the search index.
// Drafts are hidden from listings, so they must stay out of the index as well.
const searchable =
  (COLLECTION_ORDER as ListableCollection[]).includes(entry.collection) && !data.draft;
---

<Base title={`${data.title} — thnkr`} description={description} jsonLd={jsonLd}>
  <div class="flex justify-end gap-4">
    <CopyMarkdown href={mdHref} />
    {showSourcePath && <CopyPath value={sourcePath} />}
  </div>
  <article class="prose max-w-none mt-2" data-pagefind-body={searchable ? true : undefined}>
    <h1>{data.title}</h1>
    <div class="not-prose text-sm text-muted mb-6">
      <time datetime={data.pubDate.toISOString()} data-pagefind-meta="date">
        {formatDate(data.pubDate)}
      </time>
      <span> · </span>
      <span>{readingMinutes} min</span>
    </div>
    <slot />
  </article>
</Base>
