---
import type { CollectionEntry } from 'astro:content';
import CopyMarkdown from '../components/CopyMarkdown.astro';
import CopyPath from '../components/CopyPath.astro';
import { COLLECTION_ORDER, type ListableCollection, formatDate } from '../lib/collections';
import { blogPostingJsonLd } from '../lib/jsonld';
import Base from './Base.astro';

interface Props {
  entry: CollectionEntry<ListableCollection>;
  readingMinutes: number;
}

const { entry, readingMinutes } = Astro.props;
const { data } = entry;
const description = data.description ?? data.summary ?? '';
const siteUrl = Astro.site?.toString() ?? 'https://khw1031.github.io/';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const jsonLd = blogPostingJsonLd({
  title: data.title,
  description: description || undefined,
  pubDate: data.pubDate,
  updatedDate: data.updatedDate,
  url: pageUrl,
  siteUrl,
});
const mdHref = `${Astro.url.pathname.replace(/\/$/, '')}/raw.md`;
// entry.id is not always the file path (hub notes live at <id>/index.md), so
// prefer the loader-provided filePath and keep the id-based form as fallback.
const sourcePath = entry.filePath ?? `src/content/${entry.collection}/${entry.id}.md`;
// Search principle: index only public, listed collections. Notes and inbox are
// unlisted (excluded from sitemap too) and must never enter the search index.
// Drafts are hidden from listings, so they must stay out of the index as well.
const searchable =
  (COLLECTION_ORDER as ListableCollection[]).includes(entry.collection) && !data.draft;
// Tag chips link to /tags/[tag], which only exists for the public scope. Only
// public collections show them so a chip never points at a missing tag page.
const showTags =
  (COLLECTION_ORDER as ListableCollection[]).includes(entry.collection) && data.tags.length > 0;
---

<Base title={`${data.title} — thnkr`} description={description} jsonLd={jsonLd}>
  <div class="flex justify-end gap-4">
    <CopyMarkdown href={mdHref} />
    <CopyPath value={sourcePath} />
  </div>
  <article class="prose max-w-none mt-2" data-pagefind-body={searchable ? true : undefined}>
    <h1>{data.title}</h1>
    <div class="not-prose text-sm text-muted mb-6">
      <time datetime={data.pubDate.toISOString()} data-pagefind-meta="date">
        {formatDate(data.pubDate)}
      </time>
      <span> · </span>
      <span>{readingMinutes} min</span>
    </div>
    {
      data.summary && (
        <aside class="not-prose mb-14 text-[#4c82f0]">
          <div class="mb-1 flex items-center gap-1.5">
            <svg
              width="13.65"
              height="13.65"
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="tldr-mark shrink-0"
            >
              <path
                fill="currentColor"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linejoin="round"
                d="M12 2c0 5.523-4.477 10-10 10 5.523 0 10 4.477 10 10 0-5.523 4.477-10 10-10-5.523 0-10-4.477-10-10z"
              />
            </svg>
            <span class="text-[13px] font-semibold leading-none">핵심요약</span>
          </div>
          <p class="m-0 text-[13px] leading-relaxed">{data.summary}</p>
        </aside>
      )
    }
    <slot />
    {
      showTags && (
        <div class="not-prose mt-10 flex flex-wrap gap-x-3 gap-y-2 text-sm">
          {data.tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="text-muted transition-colors hover:text-foreground"
            >
              #{tag}
            </a>
          ))}
        </div>
      )
    }
  </article>
</Base>

<style>
  /* The "핵심요약" glyph ink sits slightly low in its line box, so the flex-
     centered mark reads a touch high. The optical offset depends on subpixel
     rounding, which differs by display density: standard (1x) displays need a
     larger nudge than hi-DPI (retina / mobile) ones. */
  .tldr-mark {
    transform: translateY(0.5px);
  }

  @media (min-resolution: 2dppx) {
    .tldr-mark {
      transform: none;
    }
  }
</style>
