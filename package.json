{
  "name": "khw1031.github.io",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "predev": "tsx scripts/generate-raw-markdown.ts",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --grep-invert @webgl",
    "test:e2e:webgl": "playwright test --grep @webgl",
    "import:legacy": "tsx scripts/import-from-legacy.ts",
    "theme:gen": "tsx scripts/iterm-to-css.ts",
    "prebuild": "tsx scripts/iterm-to-css.ts && tsx scripts/generate-raw-markdown.ts"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/kiwi-maru": "^5.2.8",
    "@lucide/astro": "^1.22.0",
    "astro": "^7.0.4",
    "expr-eval": "^2.0.2",
    "katex": "0.17.0",
    "pretendard": "^1.3.9",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-flexible-markers": "^1.3.5",
    "remark-gfm": "^4.0.1",
    "remark-smartypants": "^3.0.2",
    "three": "^0.185.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "@types/katex": "0.16.8",
    "@types/node": "^25.8.0",
    "@types/three": "^0.185.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.10.6",
    "pagefind": "^1.3.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.9"
  }
}
